# Server
PORT=4000
NODE_ENV=development
# One or more allowed origins, comma-separated. No trailing slashes.
# Example (prod + local dev):
# CORS_ORIGIN=https://multi-driver-transport.vercel.app,http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# PostgreSQL (local)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/multi_driver_h3
# or use the individual fields below (DATABASE_URL takes precedence)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=multi_driver_h3

# Remote DB (Render, Neon, Supabase): SSL is auto-enabled for non-local hosts.
# Force SSL: DATABASE_SSL=true  |  Disable SSL: DATABASE_SSL=false

# JWT Authentication (change secrets in production)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_RESET_SECRET=change-me-reset-secret-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30
JWT_RESET_TTL=1h
BCRYPT_ROUNDS=12

# Pricing engine — booking fee on segment sub-totals (default 0.02 = 2%). Overridden by system_settings.booking_fee_rate when set.
BOOKING_FEE_RATE=0.02
# Land road distance — google (Directions API) or h3 (cell estimate fallback).
LAND_DISTANCE_PROVIDER=google
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Land transit speed (km/h) when zone schedule is absent. Overridden by system_settings.land_speed_kmh when set.
LAND_SPEED_KMH=50
# External air/sea quote webhook (your own API). POST JSON, expect { "quoted_cost": number, "currency"?: string }.
# EXTERNAL_QUOTE_WEBHOOK_URL=https://your-api.example.com/logistics/quote
# EXTERNAL_QUOTE_API_KEY=
# EXTERNAL_QUOTE_AUTH_HEADER=Authorization
# EXTERNAL_QUOTE_TIMEOUT_MS=15000

# First user with this email gets admin role on register (optional)
ADMIN_EMAIL=admin@yourcompany.com
